{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jianghu.example.com/schemas/v7/jianghu-config-v7.schema.json",
  "title": "Jianghu V7 Config Schema",
  "description": "默认 UI（pageContent）；显式 mode:\"crud\" 走 fields/views。jh-component 用 component.path，禁止 page.id / resourceList。",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "v7"
    },
    "mode": {
      "type": "string",
      "enum": ["crud"],
      "description": "仅 CRUD 语义须显式声明；省略为 UI 模式"
    },
    "pageType": {
      "type": "string",
      "enum": ["jh-page", "jh-mobile-page", "jh-component"],
      "description": "NJK 模板族"
    },
    "targetPlatform": {
      "type": "string",
      "enum": ["pc", "mobile"]
    },
    "page": {
      "$ref": "#/definitions/pageMeta"
    },
    "component": {
      "$ref": "#/definitions/componentMeta"
    },
    "pageContent": {
      "$ref": "#/definitions/pageContentRoot"
    },
    "actionContent": {
      "type": "array"
    },
    "dataSource": {
      "$ref": "#/definitions/dataSource"
    },
    "fields": {
      "type": "object",
      "description": "mode:crud 字段字典",
      "additionalProperties": { "$ref": "#/definitions/fieldDef" }
    },
    "views": {
      "type": "object",
      "description": "mode:crud 视图",
      "additionalProperties": false,
      "properties": {
        "list": { "$ref": "#/definitions/listView" },
        "create": { "$ref": "#/definitions/formView" },
        "update": { "$ref": "#/definitions/updateView" }
      }
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pc": { "$ref": "#/definitions/platformSlice" },
        "desktop": { "$ref": "#/definitions/platformSlice" },
        "mobile": { "$ref": "#/definitions/platformSlice" }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "slots": {
      "type": "object",
      "additionalProperties": true
    },
    "common": {
      "type": "object",
      "additionalProperties": true
    },
    "includeList": {
      "$ref": "../components/include-list.schema.json#/definitions/includeListArray"
    },
    "resourceList": {
      "$ref": "../components/resource-list.schema.json#/definitions/resourceListArray"
    },
    "resourceHints": {
      "$ref": "#/definitions/resourceHints"
    },
    "pc": {
      "description": "mode:crud — (views, blocks) => { pageContent?, actionContent? }"
    },
    "mobile": {
      "description": "mode:crud — (views, blocks) => { pageContent?, actionContent? }"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "crud" } },
        "required": ["mode"]
      },
      "then": {
        "required": ["fields", "dataSource"],
        "not": { "required": ["pageContent"] }
      },
      "else": {
        "required": ["pageContent"],
        "not": {
          "anyOf": [
            { "required": ["mode"] },
            { "required": ["fields"] },
            { "required": ["views"] },
            { "required": ["dataSource"] },
            { "required": ["pc"] },
            { "required": ["mobile"] }
          ]
        }
      }
    },
    {
      "if": {
        "anyOf": [
          {
            "properties": { "pageType": { "const": "jh-component" } },
            "required": ["pageType"]
          },
          { "required": ["component"] }
        ]
      },
      "then": {
        "required": ["component"],
        "not": {
          "anyOf": [
            { "required": ["page"] },
            { "required": ["resourceList"] }
          ]
        }
      },
      "else": {
        "required": ["page"]
      }
    }
  ],
  "definitions": {
    "pageMeta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "hook": {},
        "menu": {
          "description": "false=无顶栏；true/省略→jh-menu；字符串=自定义 kebab-case 组件名",
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$" }
          ]
        },
        "targets": { "type": "string", "enum": ["pc", "mobile", "both"], "description": "UI 模式默认 pc；mode:crud 固定双端" },
        "vuetify": { "type": "object" },
        "template": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "pc": { "type": "string" },
                "mobile": { "type": "string" }
              }
            },
            { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "template.{pc,mobile}" }
          ]
        },
        "helpDoc": { "oneOf": [{ "type": "boolean" }, { "type": "string" }] }
      }
    },
    "componentMeta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "targets": { "type": "string", "enum": ["pc", "mobile", "both"] },
        "props": { "type": "object", "additionalProperties": true }
      }
    },
    "resourceHints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "actionId": { "type": "string" },
          "desc": { "type": "string" },
          "resourceType": { "type": "string" }
        }
      }
    },
    "pageContentRoot": {
      "description": "页面主体 UI 树；纯 actionContent 时可写 {}",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "maxProperties": 0
        },
        {
          "type": "object",
          "required": ["component"],
          "properties": {
            "component": { "type": "string" },
            "props": { "type": "object" },
            "attrs": { "type": "object" },
            "children": { "type": "array" },
            "key": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "dataSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "table": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "primaryKey": { "type": "string" },
        "listResource": { "type": "string" },
        "createResource": { "type": "string" },
        "updateResource": { "type": "string" },
        "deleteResource": { "type": "string" },
        "listActionId": { "type": "string" },
        "createActionId": { "type": "string" },
        "updateActionId": { "type": "string" },
        "deleteActionId": { "type": "string" },
        "getActionId": { "type": "string" },
        "resource": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "list": { "type": "string" },
            "create": { "type": "string" },
            "update": { "type": "string" },
            "delete": { "type": "string" },
            "get": { "type": "string" }
          }
        },
        "actions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "list": { "type": "string" },
            "create": { "type": "string" },
            "update": { "type": "string" },
            "delete": { "type": "string" }
          }
        }
      }
    },
    "fieldDef": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["text", "select", "number", "textarea", "date", "custom", "section", "divider", "tip"]
        },
        "column": { "$ref": "#/definitions/fieldColumnConfig" },
        "search": { "$ref": "#/definitions/fieldSearchConfig" },
        "form": { "$ref": "#/definitions/fieldFormConfig" },
        "createForm": { "$ref": "#/definitions/fieldFormConfig" },
        "updateForm": { "$ref": "#/definitions/fieldFormConfig" },
        "component": { "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.component" },
        "options": { "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.options" },
        "required": { "type": "boolean", "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.required" },
        "readonly": { "type": "boolean", "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.readonly" },
        "rules": { "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.rules" },
        "op": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "search.op" },
        "width": { "type": "number", "x-jianghu-deprecated": true, "x-jianghu-replacement": "column.width" },
        "align": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "column.align" },
        "class": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "column.class" },
        "cellClass": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "column.cellClass" },
        "html": { "type": "string", "description": "type='tip' 时的 HTML 内容" },
        "cls": { "type": "string", "description": "结构性字段或表单项额外 class" },
        "placeholder": { "type": "string", "description": "表单 placeholder", "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.placeholder" },
        "hint": { "type": "string", "description": "表单 hint（persistent-hint）", "x-jianghu-deprecated": true, "x-jianghu-replacement": "form.hint" },
        "quickAttrs": {
          "description": "布尔型 Vuetify 属性：数组 [\"clearable\"] 或空格字符串",
          "x-jianghu-deprecated": true,
          "x-jianghu-replacement": "form.quickAttrs"
        },
        "attrs": {
          "type": "object",
          "description": "透传 jh-form → Vuetify 组件 props（如 textarea.rows、select item-text）",
          "x-jianghu-deprecated": true,
          "x-jianghu-replacement": "form.attrs",
          "additionalProperties": true
        },
        "pc": {
          "type": "object",
          "description": "PC 端 attrs 覆写（直接 merge 进 fields.attrs，如 { rows: 8 }）",
          "x-jianghu-deprecated": true,
          "x-jianghu-replacement": "form.pcAttrs",
          "additionalProperties": true
        },
        "mobile": {
          "type": "object",
          "description": "Mobile 端 attrs 覆写（直接 merge 进 fields.attrs，如 { rows: 5 }）",
          "x-jianghu-deprecated": true,
          "x-jianghu-replacement": "form.mobileAttrs",
          "additionalProperties": true
        }
      }
    },
    "fieldColumnConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "width": { "type": "number" },
        "align": { "type": "string", "enum": ["start", "center", "end"] },
        "class": { "type": "string" },
        "cellClass": { "type": "string" }
      }
    },
    "fieldSearchConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "op": { "type": "string" } }
    },
    "fieldFormConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "component": { "type": "string" },
        "options": {},
        "required": { "type": "boolean" },
        "labelRequired": { "type": "boolean" },
        "readonly": { "type": "boolean" },
        "rules": {},
        "placeholder": { "type": "string" },
        "hint": { "type": "string" },
        "quickAttrs": {},
        "attrs": { "type": "object", "additionalProperties": true },
        "pcAttrs": { "type": "object", "additionalProperties": true },
        "mobileAttrs": { "type": "object", "additionalProperties": true }
      }
    },
    "fieldAttrsMap": {
      "type": "object",
      "description": "按 field key 覆写 attrs；合并于 fields.{key}.attrs 之上",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "listView": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "columnList": { "type": "array", "minItems": 1, "description": "PC 列；字段 key 或列覆盖对象" },
        "mobileColumnList": { "type": "array", "description": "Mobile 列；省略时回退 columnList" },
        "columns": { "type": "array", "x-jianghu-deprecated": true, "x-jianghu-replacement": "columnList" },
        "mobileColumns": { "type": "array", "x-jianghu-deprecated": true, "x-jianghu-replacement": "mobileColumnList" },
        "search": { "$ref": "#/definitions/searchConfig" },
        "filter": {},
        "headActionList": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/actionItem" },
              { "$ref": "#/definitions/structuralActionItem" }
            ]
          }
        },
        "rowActionList": {
          "type": "array",
          "items": { "$ref": "#/definitions/actionItem" }
        },
        "toolbarActions": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/actionItem" },
              { "$ref": "#/definitions/structuralActionItem" }
            ]
          },
          "x-jianghu-deprecated": true,
          "x-jianghu-replacement": "headActionList"
        },
        "rowActions": { "type": "array", "items": { "$ref": "#/definitions/actionItem" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "rowActionList" },
        "orderBy": { "type": "array" },
        "serverPagination": { "type": "boolean" },
        "pageSize": { "type": "number", "minimum": 1 },
        "selectable": { "type": "boolean" },
        "layout": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["table", "card"] }
          }
        },
        "mobileSearchTitle": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "search.mobileSheet.title" },
        "searchSheet": { "$ref": "#/definitions/sheetOverlay", "x-jianghu-deprecated": true, "x-jianghu-replacement": "search.mobileSheet" },
        "mobileItemAction": {
          "description": "移动端 jh-list item 行点击行为（PC Table 忽略）：'sheet'（默认，弹中继 ActionSheet）| false | 'none'（不响应）| 其他字符串（直接触发对应 doUiAction，跳过中继弹窗）",
          "oneOf": [
            { "type": "boolean", "enum": [false] },
            { "type": "string" }
          ]
        }
      }
    },
    "sheetOverlay": {
      "type": "object",
      "description": "Sheet 叠层行为（仅 FormSheet / SearchSheet / Sheet，不含 Drawer）",
      "additionalProperties": false,
      "properties": {
        "persistent": { "type": "boolean", "description": "点外侧不关闭" },
        "bodyHeightMode": { "type": "string", "enum": ["content", "fill"], "default": "fill", "description": "Sheet/FormSheet 默认 fill；SearchSheet 默认 content" },
        "rounded": { "type": "boolean", "x-jianghu-deprecated": true, "x-jianghu-replacement": "固定组件视觉" },
        "autoHeight": { "type": "boolean", "x-jianghu-deprecated": true, "x-jianghu-replacement": "bodyHeightMode" },
        "viewportOffset": { "type": "number", "x-jianghu-deprecated": true, "x-jianghu-replacement": "maxBodyHeight" },
        "maxBodyHeight": { "type": "string", "description": "内容区最大高度，如 70vh、400px" },
        "bodyHeight": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "maxBodyHeight + bodyHeightMode:'fill'" },
        "minCardHeight": { "type": "string", "x-jianghu-deprecated": true, "x-jianghu-replacement": "兼容保留" },
        "bodyClass": {},
        "beforeCloseConfirm": { "type": "boolean", "description": "FormSheet 关前脏检测" }
      }
    },
    "searchOrFilterConfig": {
      "oneOf": [
        { "type": "array", "items": { "type": "string" } },
        {
          "type": "object",
          "properties": {
            "keyword": {
              "type": "object",
              "properties": {
                "fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                "placeholder": { "type": "string" },
                "label": { "type": "string" }
              },
              "required": ["fields"]
            },
            "fields": { "type": "array" }
          }
        }
      ]
    },
    "searchConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "keyword": {
          "type": "object",
          "properties": {
            "fields": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "placeholder": { "type": "string" }
          },
          "required": ["fields"]
        },
        "fieldList": { "type": "array" },
        "fields": { "type": "array", "x-jianghu-deprecated": true, "x-jianghu-replacement": "fieldList" },
        "btnText": { "type": "string" },
        "btnIcon": { "type": "string" },
        "mobileBtnText": { "type": "string" },
        "mobileBtnIcon": { "type": "string" },
        "mobileBtnClass": { "type": "string" },
        "mobileSheet": { "$ref": "#/definitions/sheetOverlay" }
      }
    },
    "formView": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "fieldList": { "type": "array", "items": { "type": "string" } },
        "fields": { "type": "array", "items": { "type": "string" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "fieldList" },
        "interaction": { "type": "object" },
        "actionList": {
          "type": "array",
          "items": { "$ref": "#/definitions/actionItem" }
        },
        "actions": { "type": "array", "items": { "$ref": "#/definitions/actionItem" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "actionList" },
        "saveTipBeforeClose": { "type": "boolean", "x-jianghu-deprecated": true, "x-jianghu-replacement": "beforeCloseConfirm" },
        "beforeCloseConfirm": { "type": "boolean" },
        "mobileSheet": { "$ref": "#/definitions/sheetOverlay" },
        "sheet": { "$ref": "#/definitions/sheetOverlay", "x-jianghu-deprecated": true, "x-jianghu-replacement": "mobileSheet" },
        "fieldAttrs": { "$ref": "#/definitions/fieldAttrsMap", "description": "覆写 create 表单 fieldList[].attrs" }
      }
    },
    "updateView": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tabList": {
          "type": "array",
          "items": { "$ref": "#/definitions/updateTab" }
        },
        "tabs": { "type": "array", "items": { "$ref": "#/definitions/updateTab" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "tabList" },
        "fieldList": { "type": "array", "items": { "type": "string" } },
        "fields": { "type": "array", "items": { "type": "string" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "fieldList" },
        "actionList": { "type": "array", "items": { "$ref": "#/definitions/actionItem" } },
        "actions": { "type": "array", "items": { "$ref": "#/definitions/actionItem" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "actionList" },
        "mobileSheet": { "$ref": "#/definitions/sheetOverlay" },
        "sheet": { "$ref": "#/definitions/sheetOverlay", "x-jianghu-deprecated": true, "x-jianghu-replacement": "mobileSheet" },
        "fieldAttrs": { "$ref": "#/definitions/fieldAttrsMap", "description": "单表单模式覆写 fieldList[].attrs" }
      }
    },
    "platformSlice": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "list": { "type": "string" },
        "create": { "type": "string" },
        "update": { "type": "string" },
        "filter": { "type": "string", "enum": ["inline", "sheet"] }
      }
    },
    "actionItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label", "uiAction"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "uiAction": { "type": "string", "minLength": 1 },
        "color": { "type": "string" },
        "key": { "type": "string" },
        "icon": { "type": "string" },
        "confirm": { "type": "boolean" },
        "visibleWhen": {},
        "disabledWhen": {},
        "loadingWhen": {}
      },
      "not": {
        "anyOf": [
          { "required": ["intent"] },
          { "required": ["actionId"] },
          { "required": ["id"] }
        ]
      }
    },
    "structuralActionItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["spacer", "slot", "filter"] }
      }
    },
    "updateTab": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "key": { "type": "string" },
        "title": { "type": "string" },
        "fieldList": { "type": "array", "items": { "type": "string" } },
        "fields": { "type": "array", "items": { "type": "string" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "fieldList" },
        "interaction": { "type": "object" },
        "fieldAttrs": { "$ref": "#/definitions/fieldAttrsMap" },
        "actionList": {
          "type": "array",
          "items": { "$ref": "#/definitions/actionItem" }
        },
        "actions": { "type": "array", "items": { "$ref": "#/definitions/actionItem" }, "x-jianghu-deprecated": true, "x-jianghu-replacement": "actionList" }
      }
    }
  }
}
