{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jianghu.example.com/schemas/components/include-list.schema.json",
  "title": "Include List Schema",
  "description": "引入资源定义",
  "definitions": {
    "includeList": {
      "type": ["object", "string"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "资源类型"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "资源路径"
        },
        "attrs": {
          "type": "object",
          "description": "资源属性"
        },
        "includeType": {
          "type": "string",
          "description": "引入类型"
        },
        "component": {
          "type": "string",
          "description": "组件名称"
        },
        "target": {
          "description": "编译端：'pc' | 'mobile'；省略则两端都引入（v7 buildPage 按 targetPlatform 过滤）",
          "oneOf": [
            { "type": "string", "enum": ["pc", "mobile"] },
            {
              "type": "array",
              "items": { "type": "string", "enum": ["pc", "mobile"] },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        }
      },
      "required": ["type"],
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["css", "js", "html", "include"]
              }
            }
          },
          "then": {
            "required": ["path"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["vueUse", "vueComponent"]
              }
            }
          },
          "then": {
            "required": ["component"]
          }
        }
      ],
      "additionalProperties": false
    },
    "includeListArray": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/includeList"
      },
      "description": "引入资源列表；v7 可在项上设 target: pc|mobile，省略则两端共用"
    }
  }
}
