{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://jianghu.example.com/schemas/components/resource-list.schema.json",
    "title": "Resource List Schema",
    "description": "资源列表定义；resourceData 结构仅按 resourceType（sql | service）走对应 if/then 分支校验",
    "definitions": {
        "resourceList": {
            "type": "object",
            "properties": {
                "actionId": {
                    "type": "string",
                    "pattern": "^[a-zA-Z][a-zA-Z0-9_/-]*$"
                },
                "desc": { "type": "string" },
                "resourceType": {
                    "type": "string",
                    "enum": ["sql", "service"]
                },
                "resourceData": {
                    "type": "object",
                    "description": "sql / service 下的字段组合见 allOf 内按 resourceType 分支"
                },
                "resourceHook": {
                    "type": "object",
                    "properties": {
                        "before": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "service": { "type": "string", "minLength": 1 },
                                    "serviceFunction": { "type": "string", "minLength": 1 }
                                },
                                "required": ["service", "serviceFunction"],
                                "additionalProperties": false
                            }
                        },
                        "after": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "service": { "type": "string", "minLength": 1 },
                                    "serviceFunction": { "type": "string", "minLength": 1 }
                                },
                                "required": ["service", "serviceFunction"],
                                "additionalProperties": false
                            }
                        }
                    },
                    "additionalProperties": false
                }
            },
            "required": ["actionId", "resourceType", "resourceData"],
            "additionalProperties": false,
            "allOf": [
                {
                    "if": {
                        "properties": { "resourceType": { "const": "sql" } },
                        "required": ["resourceType"]
                    },
                    "then": {
                        "properties": {
                            "resourceData": {
                                "type": "object",
                                "properties": {
                                    "table": { "type": "string", "minLength": 1 },
                                    "operation": {
                                        "enum": ["select", "jhInsert", "jhUpdate", "jhDelete", "insert", "update", "delete"]
                                    },
                                    "fieldList": {
                                        "type": "array",
                                        "items": { "type": "string" }
                                    }
                                },
                                "required": ["table", "operation"],
                                "additionalProperties": false
                            }
                        }
                    },
                    "else": {
                        "if": {
                            "properties": { "resourceType": { "const": "service" } },
                            "required": ["resourceType"]
                        },
                        "then": {
                            "properties": {
                                "resourceData": {
                                    "type": "object",
                                    "properties": {
                                        "service": { "type": "string", "minLength": 1 },
                                        "serviceFunction": { "type": "string", "minLength": 1 }
                                    },
                                    "required": ["service", "serviceFunction"],
                                    "additionalProperties": false
                                }
                            }
                        }
                    }
                }
            ]
        },
        "resourceListArray": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/resourceList"
            }
        }
    }
}
